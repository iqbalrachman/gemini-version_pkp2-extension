---
// Bagian ini dieksekusi di server/GitHub saat build, BUKAN di browser pengunjung
const title = "Puri Kencana Permai II - Speed Test";
---
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <style>
      body { font-family: sans-serif; background: #fff; color: #1a202c; text-align: center; padding: 20vh 20px; }
      h1 { color: #0f172a; font-size: 3rem; margin-bottom: 10px; }
      p { color: #d4af37; font-size: 1.5rem; font-weight: bold; }
    </style>
  </head>
  <body>
    <h1>{title}</h1>
    <p>Loading Speed: Secepat Kilat ⚡</p>
    <p style="color: #666; font-size: 1rem; margin-top: 20px;">
      Jika halaman ini muncul tanpa delay putih (blank screen) lebih dari 1 detik, berarti infrastruktur kita SUKSES.
    </p>
  </body>
</html>
