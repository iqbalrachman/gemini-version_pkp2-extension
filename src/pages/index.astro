---
import Hero from '../components/Hero.astro';
import Katalog from '../components/Katalog.astro';
import Promo from '../components/Promo.astro';
import Gallery from '../components/Gallery.astro';
import Kalkulator from '../components/Kalkulator.astro';
import Artikel from '../components/Artikel.astro';

const API_URL = "https://script.google.com/macros/s/AKfycbytVSPIHnoX7I1LoZQ04q1q3EU60P8r2BYlGHKg-55Fu0G0bx7_GTiycmiAiJTNMRIX/exec";

let data = { content: {}, units: [], gallery: [], articles: [] };

try {
  const response = await fetch(API_URL);
  data = await response.json();
} catch (error) {
  console.error("Error API:", error);
}

const heroTitle = data.content.hero_title || "Puri Kencana Permai II";
const heroSubtitle = data.content.hero_subtitle || "Harga Mulai Rp 900 Jutaan | DP 0%";
const metaTitle = data.content.meta_title || "Puri Kencana Permai II - Premium";
---

<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{metaTitle}</title>
    <meta name="description" content={data.content.meta_description || "Rumah premium Cibubur"} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  
  <body class="bg-white font-poppins text-navy antialiased selection:bg-gold selection:text-white">
    
    <Hero title={heroTitle} subtitle={heroSubtitle} />
    <Katalog units={data.units} />
    <Promo />
    <Kalkulator />
    <Gallery galleryItems={data.gallery} />
    <Artikel articles={data.articles} />

  </body>
</html>
