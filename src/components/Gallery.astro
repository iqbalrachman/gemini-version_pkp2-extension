---
import { processDriveImage } from '../utils/driveImage.js';

const { galleryItems = [] } = Astro.props;
const unitPhotos = galleryItems.filter(item => item.kategori === 'unit');

// KITA PROSES FOTONYA DI SINI (SAAT GITHUB NGE-BUILD)
// Promise.all memastikan semua foto diproses secara paralel biar cepat
const processedPhotos = await Promise.all(unitPhotos.map(async (photo, index) => {
  const imageUrl = await processDriveImage(photo.drive_link, 'unit', index);
  return { ...photo, imageUrl };
}));
---

<section class="py-24 bg-white" id="galeri">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="text-center mb-16">
      <h2 class="font-playfair text-4xl md:text-5xl font-bold text-navy mb-4">Galeri Hunian</h2>
      <p class="font-poppins text-gray-500 max-w-2xl mx-auto text-lg">Jelajahi setiap sudut desain interior dan eksterior premium kami.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 auto-rows-[250px]">
      {processedPhotos.map((photo, index) => (
        <div class={`group relative overflow-hidden rounded-[1.5rem] bg-gray-100 ${index === 0 ? 'md:col-span-2 md:row-span-2' : ''}`}>
          
          <!-- SEKARANG FOTONYA NARIK DARI HASIL KOMPRESI (imageUrl) -->
          <img 
            src={import.meta.env.BASE_URL + photo.imageUrl} 
            alt={photo.caption || 'Galeri Unit'} 
            class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            loading="lazy"
          />
          
          <div class="absolute inset-0 bg-gradient-to-t from-navy/80 via-navy/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-6">
            <p class="font-poppins text-white font-medium text-lg">{photo.caption || "Desain Interior Premium"}</p>
          </div>
          
        </div>
      ))}
    </div>

  </div>
</section>
