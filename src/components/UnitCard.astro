---
const { tipe, luasTanah, luasBangunan, kamar, harga, status } = Astro.props;

// Fungsi format angka ke Rupiah
const formatRupiah = (angka) => {
  return new Intl.NumberFormat('id-ID', { style: 'currency', currency: 'IDR', maximumFractionDigits: 0 }).format(angka);
};

// Logika warna badge berdasarkan status (Biar otomatis ganti warna)
let badgeColor = "bg-gray-100 text-gray-600"; // default
const statusLower = status.toString().toLowerCase();

if (statusLower === 'available') badgeColor = "bg-green-100 text-green-700";
else if (statusLower === 'sold') badgeColor = "bg-red-100 text-red-700";
else if (statusLower === 'ready unit') badgeColor = "bg-gold text-white";
else if (statusLower === 'progress') badgeColor = "bg-blue-100 text-blue-700";
---

<div 
  class="unit-card bg-white rounded-[2rem] p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 transition-all duration-300 hover:shadow-[0_8px_30px_rgb(0,0,0,0.1)] hover:-translate-y-1" 
  data-status={statusLower}
>
  <!-- Header: Tipe & Status -->
  <div class="flex justify-between items-start mb-6">
    <h3 class="font-playfair text-2xl font-bold text-navy leading-tight w-2/3">{tipe}</h3>
    <span class={`px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider ${badgeColor}`}>
      {status}
    </span>
  </div>

  <!-- Spesifikasi -->
  <div class="flex gap-6 mb-6 text-sm font-poppins border-y border-gray-100 py-4">
    <div class="flex flex-col">
      <span class="text-xs text-gray-400 mb-1">LT / LB</span>
      <span class="font-semibold text-navy">{luasTanah} / {luasBangunan} <span class="text-gray-500 font-normal">m&sup2;</span></span>
    </div>
    <div class="w-px bg-gray-200"></div>
    <div class="flex flex-col">
      <span class="text-xs text-gray-400 mb-1">Kamar</span>
      <span class="font-semibold text-navy">{kamar} <span class="text-gray-500 font-normal">KT</span></span>
    </div>
  </div>

  <!-- Harga & CTA -->
  <div class="flex flex-col gap-4">
    <div>
      <span class="text-xs text-gray-400 block mb-1">Harga Mulai</span>
      <span class="font-poppins text-2xl font-bold text-gold">{formatRupiah(harga)}</span>
    </div>
    
    <a 
      href={`https://wa.me/6281234567890?text=Halo,%20saya%20tertarik%20dengan%20unit%20${tipe}`} 
      target="_blank" 
      class="block w-full text-center bg-navy text-white py-3.5 rounded-xl font-poppins font-medium hover:bg-navy/90 transition-colors"
    >
      Tanya Unit Ini
    </a>
  </div>
</div>
