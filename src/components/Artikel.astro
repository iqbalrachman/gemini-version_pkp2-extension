---
const { articles = [] } = Astro.props;
// Ambil 3 artikel teratas (terbaru)
const latestArticles = articles.slice(0, 3);

const formatDate = (dateString) => {
  if (!dateString) return '';
  const date = new Date(dateString);
  return new Intl.DateTimeFormat('id-ID', { day: 'numeric', month: 'long', year: 'numeric' }).format(date);
};
---

<section class="py-24 bg-white" id="artikel">
  <div class="container mx-auto px-6 max-w-6xl">
    
    <div class="flex justify-between items-end mb-10">
      <div>
        <h2 class="font-playfair text-4xl font-bold text-navy mb-2">Artikel & Edukasi</h2>
        <p class="font-poppins text-gray-500">Panduan dan tips seputar properti.</p>
      </div>
    </div>

    <!-- Mobile Horizontal Scroll (Snap) -->
    <div class="flex overflow-x-auto snap-x snap-mandatory gap-6 pb-8 -mx-6 px-6 md:mx-0 md:px-0 md:grid md:grid-cols-3 md:gap-8 hide-scrollbar">
      {latestArticles.map((artikel) => (
        <a href={`/artikel/${artikel.slug}`} class="snap-start flex-none w-80 md:w-auto group">
          <div class="bg-white border border-gray-100 rounded-2xl overflow-hidden shadow-[0_4px_20px_rgb(0,0,0,0.03)] hover:shadow-xl transition-shadow h-full flex flex-col">
            <div class="h-48 overflow-hidden bg-gray-100">
              <!-- Cover Artikel Dummy (Menunggu sistem convert gambar nyala) -->
              <img src={`https://images.unsplash.com/photo-1560518883-ce09059eeffa?q=80&w=800&auto=format&fit=crop`} alt={artikel.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="p-6 flex flex-col flex-1">
              <span class="text-xs font-bold text-gold uppercase tracking-wider mb-2">{formatDate(artikel.published_at)}</span>
              <h3 class="font-playfair text-xl font-bold text-navy mb-4 line-clamp-2 leading-snug group-hover:text-gold transition-colors">{artikel.title}</h3>
              <div class="mt-auto font-poppins text-sm font-semibold text-navy flex items-center gap-1 group-hover:gap-2 transition-all">
                Baca Selengkapnya <span>&rarr;</span>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
    
  </div>
</section>

<style>
  /* Sembunyikan scrollbar bawaan browser tapi tetap bisa di-scroll */
  .hide-scrollbar::-webkit-scrollbar { display: none; }
  .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
